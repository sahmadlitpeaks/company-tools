# Optional overrides for `docker compose up --build`.
#
# The stack boots with sensible defaults and needs NO .env to run locally — copy
# this to `.env` only if you want to change the port, set production values, or
# wire up Azure SSO / SMTP. Every value below shows its built-in default.

# ---- Where the whole app is served ----
# Host port mapped to the frontend's nginx (the single origin for everything).
APP_PORT=8080

# ---- App ----
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
# Public URLs used for QR/short-link/card URLs + SSO redirects. Leave BLANK to
# auto-derive from the request host, so the app works on any IP/domain with no
# config (e.g. http://<your-server-ip>:8080). Set them only to pin a fixed
# domain or to force https behind TLS termination.
PUBLIC_BASE_URL=
FRONTEND_BASE_URL=
BACKEND_CORS_ORIGINS=http://localhost:8080

# ---- Bootstrap admin (created only on a brand-new, empty database) ----
# You'll be forced to change this password on first login.
DEFAULT_ADMIN_EMAIL=admin@agholding.net
DEFAULT_ADMIN_PASSWORD=admin

# ---- Database (the bundled Postgres service) ----
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform

# ---- Azure Entra ID (optional; password sign-in works without it) ----
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Defaults to ${PUBLIC_BASE_URL}/api/auth/callback when left unset.
AZURE_REDIRECT_URI=

# ---- SMTP (optional: emails secure-transfer links) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@agholding.net
