# ---- App ----
APP_NAME="AG Holding Internal Platform"
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
# Comma-separated list of allowed CORS origins (the frontend)
BACKEND_CORS_ORIGINS=http://localhost:5173
# Public base URLs for QR/short-link/card URLs + SSO redirects. Leave BLANK to
# auto-derive from the request host (works on any IP/domain); set to pin a
# fixed domain or force https.
PUBLIC_BASE_URL=
FRONTEND_BASE_URL=

# ---- Bootstrap admin (seeded only when the database has no users) ----
# Forced to change this password on first login.
DEFAULT_ADMIN_EMAIL=admin@agholding.net
DEFAULT_ADMIN_PASSWORD=admin

# ---- Database ----
DATABASE_URL=postgresql+psycopg://platform:platform@localhost:5432/platform

# ---- Azure Entra ID (Azure AD) ----
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
# Where Entra redirects after the backend-side auth-code flow:
AZURE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ---- Session JWT issued by THIS backend ----
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---- File storage ----
MEDIA_ROOT=./media
MEDIA_URL=/media

# ---- SMTP (optional: emails secure-transfer links to recipients) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@agholding.net
