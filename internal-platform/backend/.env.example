# ---- App ----
APP_NAME="AG Holding Internal Platform"
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
# Comma-separated list of allowed CORS origins (the frontend)
BACKEND_CORS_ORIGINS=http://localhost:5173
# Public base URL of THIS api (used to build QR/short-link/card URLs)
PUBLIC_BASE_URL=http://localhost:8000
# Public base URL of the frontend (used for redirects after SSO)
FRONTEND_BASE_URL=http://localhost:5173

# ---- Database ----
DATABASE_URL=postgresql+psycopg://platform:platform@localhost:5432/platform

# ---- Azure Entra ID (Azure AD) ----
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
# Where Entra redirects after the backend-side auth-code flow:
AZURE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ---- Session JWT issued by THIS backend ----
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---- File storage ----
MEDIA_ROOT=./media
MEDIA_URL=/media
